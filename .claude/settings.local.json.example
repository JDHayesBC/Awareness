{
  "enabledMcpjsonServers": [
    "pps-lyra",
    "pps-caia",
    "lyra-gmail",
    "caia-gmail"
  ],
  "permissions": {
    "allow": [
      "mcp__pps__*"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PROJECT_ROOT}/pps/venv/bin/python ${PROJECT_ROOT}/.claude/hooks/inject_context.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "${PROJECT_ROOT}/pps/venv/bin/python ${PROJECT_ROOT}/.claude/hooks/inject_agent_context.py",
            "timeout": 8000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "${PROJECT_ROOT}/pps/venv/bin/python ${PROJECT_ROOT}/.claude/hooks/monitor_agent_pressure.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PROJECT_ROOT}/pps/venv/bin/python ${PROJECT_ROOT}/.claude/hooks/capture_response.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PROJECT_ROOT}/pps/venv/bin/python ${PROJECT_ROOT}/.claude/hooks/session_end.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PROJECT_ROOT}/pps/venv/bin/python ${PROJECT_ROOT}/.claude/hooks/pre_compact.py",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
